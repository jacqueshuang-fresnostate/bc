{
  "name": "mobile-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "test": "node --test",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:app": "bash scripts/build-android-apk.sh",
    "tauri:build:apk": "bash scripts/build-android-apk.sh",
    "tauri:build:apk:debug": "bash scripts/build-android-apk.sh --debug",
    "tauri:build:apk:release": "bash scripts/build-android-apk.sh --release",
    "tauri:ios:init": "tauri ios init --ci",
    "tauri:build:ios-sim": "bash scripts/run-ios-tauri-build.sh --ci --target aarch64-sim",
    "tauri:build:ios": "bash scripts/run-ios-tauri-build.sh --ci --export-method debugging",
    "tauri:build:ios-unsigned": "bash scripts/build-unsigned-ipa.sh",
    "tauri:build:desktop-app": "tauri build --bundles app",
    "tauri:build:dmg": "tauri build --bundles dmg"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@tailwindcss/vite": "^4.1.14",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-geolocation": "^2.3.2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@vant/auto-import-resolver": "^1.3.0",
    "axios": "^1.15.0",
    "emoji-mart": "^5.6.0",
    "express": "^4.21.2",
    "lucide-vue-next": "^0.546.0",
    "motion": "^12.23.24",
    "pinia": "^3.0.4",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vant": "^4.9.24",
    "vue": "^3.5.12",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vue-tsc": "^2.2.0"
  }
