# 本地后端环境变量示例。
# 复制为 .env.local 后按本机情况修改；.env.local 已被 .gitignore 忽略。

PORT=18120
DATABASE_URL=postgres://root:<密码>@192.168.2.3:15432/postgres
RUST_LOG=bc_backend=debug,tower_http=debug

# 后台可动态启用调度器；这里仅作为空库首次启动的默认值。
DRAW_SCHEDULER_ENABLED=false
DRAW_SCHEDULER_INTERVAL_SECONDS=5
DRAW_SCHEDULER_FUTURE_ISSUE_COUNT=1
DRAW_SCHEDULER_SALE_CLOSE_LEAD_SECONDS=30

# API68 默认 endpoint，可按网络代理或供应商切换进行覆盖。
API68_QUANGUOCAI_ENDPOINT=https://api.api68.com/QuanGuoCai/getLotteryInfoList.do
API68_CQSHICAI_ENDPOINT=https://api.api68.com/CQShiCai/getBaseCQShiCaiList.do
